# Copy this file to .env and fill in real values. Never commit .env.
# Schema/validation source of truth: artifacts/api-server/src/config.ts

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (lib/db, Supabase/Postgres connection string) ────────────────
DATABASE_URL=

# ── Auth (custom JWT via jose) ──────────────────────────────────────────────
# Min 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=
# Comma-separated emails that get role='admin' on first registration.
ADMIN_BOOTSTRAP_EMAILS=

# ── LLM provider (AI-assisted resource import) ──────────────────────────────
# "gemini" | "anthropic" (anthropic not implemented yet)
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash

# ── SMTP (registration / password-reset emails) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Frontend ──────────────────────────────────────────────────────────────
# Used to build links in outgoing emails (e.g. password reset).
FRONTEND_URL=http://localhost:5173

# ── CORS ────────────────────────────────────────────────────────────────────
# Leave unset in development to allow all origins. Set to the deployed
# frontend origin in production.
CORS_ORIGIN=

# ── Logging ─────────────────────────────────────────────────────────────────
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# ── Scholar APIs (upload pipeline link/metadata resolution) ─────────────────
# Polite-pool contact email for Crossref/OpenAlex, required by Unpaywall. Use a
# project mailbox (it appears in outgoing requests), not a personal one.
SCHOLAR_CONTACT_EMAIL=
# Optional — raises Semantic Scholar's rate limit. Leave empty for the free tier.
SEMANTIC_SCHOLAR_API_KEY=
